package views

import (
	"strconv"

	"github.com/khanakia/ai-logger/ent"
)

// List is the home page. Editorial header, vertical card stack.
templ List(entries []*ent.Entry, total int) {
	@Layout("Entries") {
		<div class="container--content">
			<header class="page-head">
				<h1 class="page-head__title">Recent <em>entries</em></h1>
				<span class="page-head__sub">
					{ strconv.Itoa(len(entries)) } of { strconv.Itoa(total) }
				</span>
			</header>
			if len(entries) == 0 {
				@listEmpty()
			} else {
				<div class="stack stack-3" id="entry-list">
					for _, e := range entries {
						@EntryCard(e)
					}
				</div>
			}
		</div>
	}
}

templ listEmpty() {
	<div class="empty">
		<p class="empty__quote">&ldquo;The faintest ink is more powerful than the strongest memory.&rdquo;</p>
		<p class="empty__cite">— Chinese proverb</p>
		<p class="empty__hint">
			Run <code>ailog hooks install</code> and start a Claude Code session.
		</p>
	</div>
}
